{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user preferences and basic profile info.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "favoriteCountries": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "email", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document indexed by UID."
    }
  }
}
